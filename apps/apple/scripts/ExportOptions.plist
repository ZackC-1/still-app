<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Store distribution export (U20). Managed signing resolves the distribution cert + the
	     app + extension provisioning profiles via the App Store Connect API key passed to xcodebuild. -->
	<key>method</key>
	<string>app-store-connect</string>
	<key>teamID</key>
	<string>UM9HVDH3P3</string>
	<key>signingStyle</key>
	<string>automatic</string>
	<key>uploadSymbols</key>
	<true/>
	<key>destination</key>
	<string>export</string>
</dict>
</plist>
