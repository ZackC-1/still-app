# Still — environment template.
#
# Copy to `.env.local` and fill in. NEVER commit a real value — only this template is tracked
# (.gitignore ignores `.env.*` and excepts `.env.example`).
#
# Legend on each key:
#   [loop-ok]      safe to load into the autonomous /loop environment
#   [HUMAN-ONLY]   must NEVER be present in any loop-accessible .env — a separate human deploy step
#   [edge-secret]  set on the deployed function via `supabase secrets set`, not in client bundles
#
# Edge Function secrets are configured with `supabase secrets set NAME=value` (see docs/CONNECTIONS.md),
# not read from this file at runtime; they are listed here so the full secret surface is in one place.

# ── Supabase (client) ──────────────────────────────────────────────────────────
# [loop-ok] Public project URL + anon key. Safe in client bundles; RLS is the real boundary.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Supabase (server / migrations only) ─────────────────────────────────────────
# [HUMAN-ONLY] Full service-role key bypasses RLS — used only for migrations and the
# delete-user function (U15). Keep out of the loop env and out of any client bundle.
SUPABASE_SERVICE_ROLE_KEY=
# [HUMAN-ONLY] Direct DB connection string for `supabase db push` (pooler endpoint — the
# direct host is IPv6-only/unreachable from local Docker; see project memory).
SUPABASE_DB_URL=

# ── Narrow entitlement-write credential (U11/U14) ───────────────────────────────
# [edge-secret] Secret used by the webhook + reconcile functions to call the narrow
# entitlement-write RPC / custom Postgres role — NOT the full service-role key (KTD5).
ENTITLEMENT_WRITE_RPC_SECRET=

# ── RevenueCat (U14 / U19) ──────────────────────────────────────────────────────
# [loop-ok] Public SDK key shipped in the Apple app to configure Purchases.
REVENUECAT_PUBLIC_API_KEY=
# [edge-secret] Secret API key for server-side `GET /subscribers/{app_user_id}` lookups.
REVENUECAT_SECRET_API_KEY=
# [edge-secret] Static bearer token RevenueCat sends in the webhook Authorization header;
# compared constant-time as the webhook's primary gate (KTD5). Never logged.
REVENUECAT_WEBHOOK_TOKEN=

# ── Rule-set signing (U5 / U12) ─────────────────────────────────────────────────
# [HUMAN-ONLY] Ed25519 PRIVATE signing key for published rule sets. NEVER loaded into the
# loop env — signing is a separate human-only deploy step (U2). Tests use a deterministic
# throwaway test keypair generated in-test, never this key.
RULE_SET_SIGNING_PRIVATE_KEY=
# [loop-ok] Key id (kid) of the current signing key, embedded so clients pick the right pubkey.
RULE_SET_SIGNING_KID=

# ── Email / magic link (U13 / KTD9) ─────────────────────────────────────────────
# [HUMAN-ONLY + DNS] Resend API key + verified sender domain. Built-in Supabase auth email
# caps at ~2/hour → launch blocker for magic link.
RESEND_API_KEY=
RESEND_SENDER_DOMAIN=

# ── Selector canary notify (U21) ────────────────────────────────────────────────
# [edge-secret] Outbound webhook/email URL the canary posts to when a surface breaks or is
# unverifiable for too long. If unset, the canary logs and no-ops without crashing.
SELECTOR_CANARY_NOTIFY_URL=

# ── Observability (optional) ────────────────────────────────────────────────────
# [loop-ok] Sentry DSN. Optional in v1 (crash reporting only).
SENTRY_DSN=
