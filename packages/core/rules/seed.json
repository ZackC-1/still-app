{
  "version": "1.0.0",
  "services": {
    "youtube": {
      "matches": [
        "*://*.youtube.com/*",
        "*://m.youtube.com/*"
      ],
      "surfaces": [
        {
          "id": "yt-shorts-redirect",
          "label": "Shorts URL → watch page",
          "tier": "free",
          "action": "redirect",
          "enabledByDefault": true,
          "redirect": {
            "urlMatch": "^/shorts(?:/([\\w-]+))?/?$",
            "to": "/watch?v=$1",
            "fallbackToPlaceholder": true
          }
        },
        {
          "id": "yt-sidebar",
          "label": "Shorts in left guide + mini-guide",
          "tier": "free",
          "action": "hide",
          "enabledByDefault": true,
          "selectors": [
            "ytd-guide-entry-renderer:has(a[title=\"Shorts\"])",
            "ytd-mini-guide-entry-renderer:has(a[title=\"Shorts\"])",
            "a#endpoint[title=\"Shorts\"]",
            "ytm-pivot-bar-item-renderer:has(a[href=\"/shorts\"])"
          ]
        },
        {
          "id": "yt-home-shelf",
          "label": "Shorts shelf on Home",
          "tier": "free",
          "action": "remove",
          "enabledByDefault": true,
          "selectors": [
            "ytd-reel-shelf-renderer",
            "ytd-rich-section-renderer:has(ytd-rich-shelf-renderer[is-shorts])",
            "ytm-reel-shelf-renderer"
          ]
        },
        {
          "id": "yt-search",
          "label": "Shorts shelf + results in Search",
          "tier": "free",
          "action": "remove",
          "enabledByDefault": true,
          "selectors": [
            "ytd-reel-shelf-renderer",
            "ytd-video-renderer:has(a[href^=\"/shorts/\"])"
          ]
        },
        {
          "id": "yt-subscriptions",
          "label": "Shorts row in Subscriptions",
          "tier": "free",
          "action": "remove",
          "enabledByDefault": true,
          "selectors": [
            "ytd-reel-shelf-renderer"
          ]
        },
        {
          "id": "yt-channel-tab",
          "label": "Shorts tab on channel pages",
          "tier": "free",
          "action": "hide",
          "enabledByDefault": true,
          "selectors": [
            "yt-tab-shape[tab-title=\"Shorts\"]",
            "tp-yt-paper-tab:has([href$=\"/shorts\"])"
          ]
        },
        {
          "id": "yt-chips",
          "label": "Shorts chip in pivot/chip bars",
          "tier": "free",
          "action": "hide",
          "enabledByDefault": true,
          "selectors": [
            "yt-chip-cloud-chip-renderer:has([title=\"Shorts\"])"
          ]
        }
      ]
    },
    "instagram": {
      "matches": [
        "*://*.instagram.com/*"
      ],
      "surfaces": [
        {
          "id": "ig-reels-url",
          "label": "Direct Reels URL → placeholder",
          "tier": "pro",
          "action": "placeholder",
          "enabledByDefault": true,
          "urlMatch": "^/reels?(/|$)"
        },
        {
          "id": "ig-nav",
          "label": "Reels nav (sidebar + bottom tab)",
          "tier": "pro",
          "action": "hide",
          "enabledByDefault": true,
          "selectors": [
            "a[href=\"/reels/\"]",
            "a:has(svg[aria-label=\"Reels\"])",
            "[role=\"tablist\"] a[href*=\"/reels\"]"
          ]
        },
        {
          "id": "ig-inline",
          "label": "Reels embedded in Home feed",
          "tier": "pro",
          "action": "remove",
          "enabledByDefault": true,
          "selectors": [
            "article:has(a[href^=\"/reel/\"])"
          ]
        },
        {
          "id": "ig-explore-search",
          "label": "Reel tiles in Explore + Search",
          "tier": "pro",
          "action": "remove",
          "enabledByDefault": true,
          "selectors": [
            "a[href^=\"/reel/\"]:has(span[aria-label*=\"Clip\"])",
            "a[href^=\"/reel/\"] > div > svg[aria-label=\"Clip\"]"
          ]
        },
        {
          "id": "ig-suggested",
          "label": "Suggested Reels",
          "tier": "pro",
          "action": "remove",
          "enabledByDefault": true,
          "selectors": [
            "section:has(> a[href^=\"/reel/\"])"
          ]
        },
        {
          "id": "ig-profile-tab",
          "label": "Reels tab on profile grids",
          "tier": "pro",
          "action": "hide",
          "enabledByDefault": true,
          "selectors": [
            "a[href$=\"/reels/\"]"
          ]
        }
      ]
    },
    "tiktok": {
      "matches": [
        "*://*.tiktok.com/*"
      ],
      "surfaces": [
        {
          "id": "tt-blocksite",
          "label": "All of tiktok.com → placeholder",
          "tier": "pro",
          "action": "blockSite",
          "enabledByDefault": true
        }
      ]
    },
    "facebook": {
      "matches": [
        "*://*.facebook.com/*",
        "*://m.facebook.com/*"
      ],
      "surfaces": [
        {
          "id": "fb-reel-url",
          "label": "Direct Reel URL → placeholder",
          "tier": "pro",
          "action": "placeholder",
          "enabledByDefault": true,
          "urlMatch": "^/reel/"
        },
        {
          "id": "fb-feed",
          "label": "Reels in Home feed",
          "tier": "pro",
          "action": "remove",
          "enabledByDefault": true,
          "selectors": [
            "div[role=\"article\"]:has(a[href*=\"/reel/\"])"
          ]
        },
        {
          "id": "fb-left-menu",
          "label": "Reels shortcut in left menu",
          "tier": "pro",
          "action": "hide",
          "enabledByDefault": true,
          "selectors": [
            "a[aria-label=\"Reels\"]",
            "li:has(> a[href*=\"/reel\"])"
          ]
        },
        {
          "id": "fb-watch",
          "label": "Reels inside Watch",
          "tier": "pro",
          "action": "remove",
          "enabledByDefault": true,
          "selectors": [
            "div:has(> a[href*=\"/reel/\"])"
          ]
        },
        {
          "id": "fb-search-groups",
          "label": "Reels in Search + Groups",
          "tier": "pro",
          "action": "remove",
          "enabledByDefault": true,
          "selectors": [
            "div[role=\"article\"]:has(a[href*=\"/reel/\"])"
          ]
        },
        {
          "id": "fb-suggested",
          "label": "Suggested + related Reels",
          "tier": "pro",
          "action": "remove",
          "enabledByDefault": true,
          "selectors": [
            "div[role=\"article\"]:has(a[href*=\"/reel/\"])"
          ]
        }
      ]
    }
  },
  "signature": {
    "kid": "still-dev-1",
    "alg": "ed25519",
    "value": "921f676dc6abffca9207cb1bc7b34530d0316cf517fad51129e7f9cce3f5659de961f6bdfe7b52f4dba588c4c99e6c65b456aa6a1d08aaf9dd2a7137148e840c"
  }
}
