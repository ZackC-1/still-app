{
  "name": "@still/ext-safari",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt -b safari",
    "gen-css": "node ../core/scripts/gen-content-css.mjs entrypoints/content",
    "build": "node ../core/scripts/gen-content-css.mjs entrypoints/content && wxt build -b safari",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@still/core": "workspace:*",
    "@still/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.0",
    "@wxt-dev/module-svelte": "^2.0.5",
    "svelte": "^5.56.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "wxt": "^0.20.27"
  }
}
